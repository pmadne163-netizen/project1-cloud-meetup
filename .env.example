# AWS region — the S3 bucket must live in this same region
AWS_REGION=ap-south-1

# Leave AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY BLANK on EC2 - the IAM role
# attached to the instance (see Step 1 of the deployment guide) handles
# S3 auth automatically via the SDK's default credential chain.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 bucket that stores each meetup as a JSON object
S3_BUCKET=kucl-meetup-project-xxxxxxxx
# Key prefix ("folder") under which meetup JSON files are stored
S3_PREFIX=meetups/
